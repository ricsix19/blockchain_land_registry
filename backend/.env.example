# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (connection string)
DATABASE_URL=postgres://user:password@localhost:5432/land_registry

# Auth (set JWT_SECRET in any shared environment)
JWT_SECRET=change-me-in-production

# Ethereum / LandRegistry (Option B: server submits txs)
CHAIN_RPC_URL=http://127.0.0.1:8545
LAND_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
REGISTRY_ADMIN_PRIVATE_KEY=
# Must be the current on-chain owner when executing POST .../buy
PROPERTY_TRANSFER_PRIVATE_KEY=
